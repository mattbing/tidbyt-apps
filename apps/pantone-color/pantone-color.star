def format_name(name):
    """Convert hyphenated name to title case with spaces."""
    return " ".join([w[0].upper() + w[1:] if len(w) > 0 else w for w in name.split("-")])

def main():
    colors = json.decode(PANTONE_JSON)
    keys = sorted(colors.keys())
    idx = random.number(0, len(keys) - 1)
    key = keys[idx]
    color = colors[key]
    hex_color = "#" + color["hex"]
    name = format_name(color["name"])

    return render.Root(
        child = render.Box(
            child = render.Row(
                main_align = "space_evenly",
                cross_align = "center",
                children = [
                    render.Box(
                        width = 22,
                        height = 22,
                        color = hex_color,
                    ),
                    render.Box(width = 3, height = 1),
                    render.Column(
                        main_align = "center",
                        cross_align = "center",
                        children = [
                            render.Marquee(
                                width = 38,
                                child = render.Text(
                                    content = name,
                                    font = "tom-thumb",
                                    color = "#ffffff",
                                ),
                            ),
                            render.Box(width = 1, height = 2),
                            render.Text(
                                content = key,
                                font = "tom-thumb",
                                color = "#aaaaaa",
                            ),
                        ],
                    ),
                ],
            ),
        ),
    )
